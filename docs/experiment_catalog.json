{
  "version": "1.0",
  "dataset": "olist_brazilian_ecommerce",
  "experiments": [
    {
      "id": "exp_001",
      "name": "Free Shipping Threshold",
      "primary_metric": "conversion_rate",
      "mde_percent": 10,
      "mde_type": "relative",
      "test_type": "chi_square",
      "sample_per_variant": 2450,
      "randomization_unit": "customer_id",
      "split": "50/50",
      "variants": ["control_50", "treatment_35"],
      "guardrail_metrics": ["profit_margin", "return_rate", "review_score"]
    },
    {
      "id": "exp_002",
      "name": "Payment Installments (6 vs 12 months)",
      "primary_metric": "conversion_rate_high_ticket",
      "mde_percent": 15,
      "mde_type": "relative",
      "test_type": "chi_square",
      "sample_per_variant": 3200,
      "randomization_unit": "customer_id",
      "split": "50/50",
      "variants": ["control_6_installments", "treatment_12_installments"],
      "guardrail_metrics": ["default_rate", "approval_rate"]
    },
    {
      "id": "exp_003",
      "name": "One-Page Checkout",
      "primary_metric": "checkout_completion_rate",
      "mde_percent": 8,
      "mde_type": "relative",
      "test_type": "chi_square",
      "sample_per_variant": 3500,
      "randomization_unit": "order_id",
      "split": "50/50",
      "variants": ["control_multi_step", "treatment_one_page"],
      "guardrail_metrics": ["payment_errors", "address_corrections"]
    },
    {
      "id": "exp_004",
      "name": "Review Solicitation Timing (3d vs 7d)",
      "primary_metric": "review_rate",
      "mde_percent": 20,
      "mde_type": "relative",
      "test_type": "chi_square",
      "sample_per_variant": 1800,
      "randomization_unit": "order_id",
      "split": "50/50",
      "variants": ["control_7_days", "treatment_3_days"],
      "guardrail_metrics": ["review_score"]
    },
    {
      "id": "exp_005",
      "name": "Product Recommendations (Personalized vs Popular)",
      "primary_metric": "add_to_cart_rate",
      "mde_percent": 12,
      "mde_type": "relative",
      "test_type": "chi_square",
      "sample_per_variant": 2700,
      "randomization_unit": "customer_id",
      "split": "50/50",
      "variants": ["control_popular", "treatment_personalized"],
      "guardrail_metrics": ["recommendation_diversity"]
    },
    {
      "id": "exp_006",
      "name": "Delivery Speed Options (Standard vs Express)",
      "primary_metric": "conversion_rate",
      "mde_percent": 5,
      "mde_type": "relative",
      "test_type": "chi_square",
      "sample_per_variant": 6200,
      "randomization_unit": "customer_id",
      "split": "50/50",
      "variants": ["control_standard_only", "treatment_express_option"],
      "guardrail_metrics": ["on_time_delivery_rate"]
    },
    {
      "id": "exp_007",
      "name": "Seller Ratings Display (Show vs Hide)",
      "primary_metric": "conversion_rate_low_rated_sellers",
      "mde_percent": 10,
      "mde_type": "relative",
      "test_type": "chi_square",
      "sample_per_variant": 2500,
      "randomization_unit": "order_id",
      "split": "50/50",
      "variants": ["control_show_rating", "treatment_hide_rating"],
      "guardrail_metrics": ["post_purchase_satisfaction"]
    },
    {
      "id": "exp_008",
      "name": "Bundle Discounts (3 items for 10% off)",
      "primary_metric": "items_per_order",
      "mde_percent": 15,
      "mde_type": "relative",
      "test_type": "t_test",
      "sample_per_variant": 350,
      "randomization_unit": "customer_id",
      "split": "50/50",
      "variants": ["control_no_bundle", "treatment_bundle_10pct"],
      "guardrail_metrics": ["margin"]
    },
    {
      "id": "exp_009",
      "name": "Guest Checkout (Guest vs Forced Registration)",
      "primary_metric": "conversion_rate",
      "mde_percent": 15,
      "mde_type": "relative",
      "test_type": "chi_square",
      "sample_per_variant": 1900,
      "randomization_unit": "customer_id",
      "split": "50/50",
      "variants": ["control_forced_registration", "treatment_guest_checkout"],
      "guardrail_metrics": ["ltv_guest_vs_registered"]
    },
    {
      "id": "exp_010",
      "name": "Dynamic Pricing (Demand-Based)",
      "primary_metric": "revenue_per_order",
      "mde_percent": 5,
      "mde_type": "relative",
      "test_type": "t_test",
      "sample_per_variant": 1200,
      "randomization_unit": "order_id",
      "split": "50/50",
      "variants": ["control_static", "treatment_dynamic_plus_3pct"],
      "guardrail_metrics": ["volume_change"]
    }
  ]
}
